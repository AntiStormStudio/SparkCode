{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spark Code",
  "version": "0.2.1",
  "identifier": "top.spark-ai.sparkcode-app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run prepare:backend && bun run build",
    "devUrl": "http://127.0.0.1:5188",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Spark Code",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "visible": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "nsis"],
    "resources": {
      "resources/spark-code-backend.tar.gz": "spark-code-backend.tar.gz"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
